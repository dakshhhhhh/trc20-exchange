{
  "expo": {
    "name": "CRYPTO",
    "slug": "trc20-exchange",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A8A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trc20.exchange"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.trc20.exchange",
      "versionCode": 1,
      "permissions": ["READ_EXTERNAL_STORAGE","WRITE_EXTERNAL_STORAGE","CAMERA"]
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [["expo-image-picker",{"photosPermission":"CRYPTO needs access to your photos to upload payment proof.","cameraPermission":"CRYPTO needs access to your camera to capture payment proof."}]]
  }
}
